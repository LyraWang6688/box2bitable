{
  "order": ["purchase", "sales", "inventory"],
  "modules": {
    "purchase": {
      "key": "purchase",
      "label": "采购",
      "desc": "数量累加写入采购表",
      "reviewLayout": "grouped",
      "defaults": {
        "quantity": 1
      },
      "requiredGroupFields": ["category"],
      "ui": {
        "includeSkuCode": true,
        "showSupplierField": true,
        "showSalesFields": false
      },
      "recognition": {
        "requireSupplier": true
      },
      "sync": {
        "payloadMode": "aggregate_by_sku"
      },
      "writeMode": "upsert_accumulate",
      "fields": {
        "hasSupplier": true,
        "hasSalesManual": false,
        "includeSkuCode": true
      }
    },
    "sales": {
      "key": "sales",
      "label": "销售",
      "desc": "明细流水（每次新增）",
      "reviewLayout": "list",
      "defaults": {
        "quantity": 1,
        "amount": "",
        "pay_method": "",
        "remark": ""
      },
      "requiredGroupFields": [],
      "ui": {
        "includeSkuCode": false,
        "showSupplierField": false,
        "showSalesFields": true
      },
      "recognition": {
        "requireSupplier": false
      },
      "sync": {
        "payloadMode": "detail_rows"
      },
      "writeMode": "create_detail",
      "fields": {
        "hasSupplier": false,
        "hasSalesManual": true,
        "includeSkuCode": false
      }
    },
    "inventory": {
      "key": "inventory",
      "label": "库存",
      "desc": "数量累加写入库存表",
      "reviewLayout": "list",
      "defaults": {
        "quantity": 1
      },
      "requiredGroupFields": [],
      "ui": {
        "includeSkuCode": true,
        "showSupplierField": false,
        "showSalesFields": false
      },
      "recognition": {
        "requireSupplier": false
      },
      "sync": {
        "payloadMode": "aggregate_by_sku"
      },
      "writeMode": "upsert_accumulate",
      "fields": {
        "hasSupplier": false,
        "hasSalesManual": false,
        "includeSkuCode": true
      }
    }
  }
}
