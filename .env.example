# Server Config
PORT=3000
API_KEY=your_api_key
ENABLE_CORS=false
UPLOAD_TTL_MS=86400000
UPLOAD_CLEAN_INTERVAL_MS=3600000

FEISHU_SYNC_CONCURRENCY=4
FEISHU_RETRY_MAX=3
FEISHU_RETRY_BASE_MS=300
FEISHU_RETRY_MAX_DELAY_MS=4000

# Doubao (Volcengine) Config
ARK_API_KEY=your_doubao_api_key
ARK_MODEL_ENDPOINT=your_doubao_endpoint_id
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Feishu Config
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BITABLE_APP_TOKEN=your_feishu_bitable_app_token

# Bitable Tables (by module)
# purchase: 采购录入（数量累加）
FEISHU_BITABLE_PURCHASE_TABLE_ID=your_purchase_table_id
# legacy sales detail table (kept while the old sync flow is still available)
FEISHU_BITABLE_SALES_TABLE_ID=your_sales_table_id
# sales order flow: 销售总单 / 销售子单 / 资金流水
FEISHU_BITABLE_SALES_MASTER_TABLE_ID=your_sales_master_table_id
FEISHU_BITABLE_SALES_ITEM_TABLE_ID=your_sales_item_table_id
FEISHU_BITABLE_PAYMENT_TABLE_ID=your_payment_flow_table_id
# inventory: 库存录入（数量累加）+ 库存查询数据源
FEISHU_BITABLE_INVENTORY_TABLE_ID=your_inventory_table_id

# Backward compatible default (legacy single-table setting)
# Backward compatible default (legacy single-table setting)
# Backward compatible default (legacy single-table setting)
# Backward compatible default (legacy single-table setting)
# Backward compatibl (legacy single-table setting)
# 当前代码如仍读取 FEISHU_BITABLE_TABLE_ID，可先指向采购表；后续模块化后将分别读取上面的三个变量
FEISHU_BITABLE_TABLE_ID=your_default_table_id

# Wechat Mini Program
WX_APP_ID=your_wx_app_id
WX_APP_SECRET=your_wx_app_secret
