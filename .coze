[project]
requires = ["nodejs-24"]
project_type = ""

[preview]
preview_enable = "disabled"

[deploy.profile]
kind = "service"
flavor = "web"

[deploy]
build = ["bash", "server/scripts/deploy_build.sh"]
run = ["bash", "server/scripts/deploy_run.sh"]

[subprojects]
path = ["server", "miniprogram", "supabase"]
