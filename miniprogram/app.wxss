/* ============================================
   Design Tokens - 全局设计变量
   ============================================ */
page {
  /* 主色调 */
  --color-primary: #3370FF;
  --color-primary-light: #5B8DEF;
  --color-primary-dark: #2557CC;
  --color-primary-bg: rgba(51, 112, 255, 0.08);

  /* 辅助色 */
  --color-success: #34C759;
  --color-success-bg: rgba(52, 199, 89, 0.12);
  --color-warning: #FF9500;
  --color-warning-bg: rgba(255, 149, 0, 0.12);
  --color-danger: #FF3B30;
  --color-danger-bg: rgba(255, 59, 48, 0.12);

  /* 中性色 */
  --color-text-primary: #1F2329;
  --color-text-secondary: #4E5969;
  --color-text-tertiary: #646A73;
  --color-text-placeholder: #8F959E;
  --color-text-disabled: #C4C4C4;

  /* 背景色 */
  --color-bg-base: #F2F3F5;
  --color-bg-container: #F7F8FA;
  --color-bg-card: #FFFFFF;
  --color-bg-input: #F5F6F7;
  --color-bg-hover: rgba(0, 0, 0, 0.04);

  /* 边框 */
  --color-border: #E5E6EB;
  --color-border-light: #F2F3F5;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 20rpx;
  --spacing-xl: 24rpx;
  --spacing-xxl: 30rpx;

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-full: 999rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);

  /* 字体大小 */
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 26rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 40rpx;
  --font-size-title: 44rpx;
}

/* ============================================
   Global Resets & Base
   ============================================ */
page {
  background-color: var(--color-bg-container);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ============================================
   Button Styles - 全局按钮样式
   ============================================ */
button {
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  transition: all 0.2s ease;
}

button:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%) !important;
  color: #fff !important;
  box-shadow: 0 4rpx 16rpx rgba(51, 112, 255, 0.3);
}

.btn-primary:active {
  background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%) !important;
  box-shadow: 0 2rpx 8rpx rgba(51, 112, 255, 0.2);
}

/* 通用操作按钮 */
.btn-action {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  padding: 16rpx 32rpx;
  font-size: var(--font-size-md);
  box-shadow: var(--shadow-md);
}

/* 危险按钮 */
.btn-danger {
  background: transparent;
  color: var(--color-danger) !important;
  border: 1rpx solid var(--color-danger);
}

/* ============================================
   Input Styles - 全局输入框样式
   ============================================ */
.input {
  height: 80rpx;
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  transition: all 0.2s ease;
}

.input:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
  box-shadow: 0 0 0 4rpx rgba(51, 112, 255, 0.1);
}

.input::placeholder {
  color: var(--color-text-placeholder);
}

/* ============================================
   Card Styles - 全局卡片样式
   ============================================ */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  box-shadow: var(--shadow-sm);
  transition: all 0.25s ease;
}

.card:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-md);
}

/* ============================================
   Badge Styles - 全局徽章样式
   ============================================ */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 500;
  line-height: 1.4;
}

.status-success {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.status-failed {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.status-warning {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

/* ============================================
   Utility Classes - 工具类
   ============================================ */
.text-primary { color: var(--color-primary); }
.text-success { color: var(--color-success); }
.text-danger { color: var(--color-danger); }
.text-warning { color: var(--color-warning); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.text-placeholder { color: var(--color-text-placeholder); }

.bg-primary { background-color: var(--color-primary-bg); }
.bg-success { background-color: var(--color-success-bg); }
.bg-danger { background-color: var(--color-danger-bg); }
.bg-warning { background-color: var(--color-warning-bg); }

/* Flex helpers */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { justify-content: center; align-items: center; }
.flex-between { justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }
.gap-lg { gap: var(--spacing-lg); }

/* Spacing */
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }
