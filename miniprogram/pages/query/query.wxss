/* ============================================
   Query Page - 查询页样式
   ============================================ */
.container {
  padding: 32rpx;
  background: linear-gradient(180deg, #EEF2FF 0%, #F7F8FA 30%);
  min-height: 100vh;
}

/* Header Section */
.header {
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.header-icon {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.header-icon-inner {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #34C759 0%, #2EA043 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(52, 199, 89, 0.25);
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2329;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8F959E;
}

/* Search Section */
.search {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.input {
  flex: 1;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid #E5E6EB;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1F2329;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.input:focus {
  border-color: #34C759;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.1);
}

.input::placeholder {
  color: #C4C4C4;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #34C759 0%, #2EA043 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(52, 199, 89, 0.3);
  transition: all 0.2s ease;
}

.btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(52, 199, 89, 0.2);
}

.btn[disabled] {
  background: #C4C4C4;
  box-shadow: none;
}

/* Result Section */
.result {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F2F3F5;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F2F3F5;
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2329;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.result-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #34C759 0%, #2EA043 100%);
  border-radius: 3rpx;
}

.result-count {
  font-size: 24rpx;
  color: #8F959E;
  background: #F2F3F5;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
}

/* Result Row */
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
  transition: all 0.2s ease;
}

.row:last-child {
  border-bottom: none;
}

.row:active {
  background: #FAFBFC;
  margin: 0 -16rpx;
  padding: 24rpx 16rpx;
  border-radius: 12rpx;
}

.cell {
  font-size: 28rpx;
  color: #1F2329;
}

.size {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-weight: 500;
}

.size::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  background: linear-gradient(135deg, #34C759 0%, #2EA043 100%);
  border-radius: 50%;
}

.qty {
  font-weight: 700;
  color: #34C759;
  font-size: 32rpx;
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 32rpx;
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.1) 0%, rgba(46, 160, 67, 0.1) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8F959E;
  line-height: 1.6;
}

/* History Section */
.history-section {
  margin-top: 40rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2329;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: #646A73;
  border: 1rpx solid #E5E6EB;
  transition: all 0.2s ease;
}

.history-item:active {
  background: #F7F8FA;
  border-color: #34C759;
  color: #34C759;
}
