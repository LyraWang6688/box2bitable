/* ============================================
   Review Page - 复核页样式
   ============================================ */
.container {
  padding: 32rpx;
  background-color: #F7F8FA;
  display: block;
}

/* Header Section */
.header {
  margin-bottom: 28rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #3370FF 0%, #5B8DEF 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(51, 112, 255, 0.25);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  display: block;
}

/* Result List */
.result-list {
  height: calc(100vh - 280rpx);
  padding-bottom: 40rpx;
}

/* Card Base */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F2F3F5;
}

/* Group Card */
.group-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F2F3F5;
  overflow: hidden;
}

/* Group Header */
.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F2F3F5;
}

.group-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2329;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.group-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #3370FF 0%, #5B8DEF 100%);
  border-radius: 4rpx;
}

.group-count {
  font-size: 24rpx;
  color: #8F959E;
  background: #F2F3F5;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

/* Card Header */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F2F3F5;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.supplier-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2329;
}

.tag {
  font-size: 22rpx;
  color: #8F959E;
  background: #F2F3F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* Status Badge */
.status-badge {
  padding: 8rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
}

.status-success {
  background: rgba(52, 199, 89, 0.12);
  color: #34C759;
}

.status-failed {
  background: rgba(255, 59, 48, 0.12);
  color: #FF3B30;
}

/* SKU Line */
.sku-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
}

.sku-label {
  font-size: 22rpx;
  color: #8F959E;
}

.sku-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2329;
  font-family: 'SF Mono', Monaco, monospace;
}

/* Form Items */
.group-form {
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.label {
  font-size: 24rpx;
  color: #646A73;
  margin-bottom: 10rpx;
  display: block;
  font-weight: 500;
}

/* Input */
.input {
  height: 80rpx;
  background: #F5F6F7;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1F2329;
  transition: all 0.2s ease;
}

.input:focus {
  border-color: #3370FF;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(51, 112, 255, 0.1);
}

/* Picker */
.picker {
  height: 80rpx;
  background: #F5F6F7;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.picker:focus {
  border-color: #3370FF;
  background: #fff;
}

.picker-placeholder {
  color: #8F959E;
}

.picker-text {
  font-size: 28rpx;
  color: #1F2329;
}

/* Table */
.table {
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #F2F3F5;
  margin-top: 16rpx;
}

.table-header {
  display: flex;
  background: linear-gradient(135deg, #F7F8FA 0%, #EEF2FF 100%);
  padding: 18rpx 16rpx;
}

.th {
  font-size: 22rpx;
  color: #646A73;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.th-size {
  flex: 1;
}

.th-qty {
  flex: 1;
}

.th-status {
  width: 120rpx;
  text-align: center;
}

.th-actions {
  width: 120rpx;
  text-align: center;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-top: 1rpx solid #F2F3F5;
  background: #fff;
}

.table-row:nth-child(even) {
  background: #FAFBFC;
}

.cell {
  font-size: 26rpx;
  color: #1F2329;
}

.input-cell {
  flex: 1;
  height: 64rpx;
  background: #fff;
  border: 2rpx solid #E5E6EB;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #1F2329;
  transition: all 0.2s ease;
}

.input-cell:focus {
  border-color: #3370FF;
  box-shadow: 0 0 0 3rpx rgba(51, 112, 255, 0.1);
}

.status-cell {
  width: 120rpx;
  display: flex;
  justify-content: center;
}

.action-cell {
  width: 120rpx;
  display: flex;
  justify-content: center;
}

/* Delete Button */
.btn-delete-mini {
  color: #FF3B30 !important;
  border: 1rpx solid #FF3B30 !important;
  background: rgba(255, 59, 48, 0.06) !important;
  font-size: 22rpx !important;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.btn-delete {
  background: rgba(255, 59, 48, 0.08);
  color: #FF3B30;
  border: 1rpx solid #FF3B30;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
}

/* Sync Error */
.sync-error {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 59, 48, 0.08);
  border-radius: 12rpx;
  border-left: 4rpx solid #FF3B30;
}

.sync-error-text {
  font-size: 22rpx;
  color: #FF3B30;
  line-height: 1.5;
}

/* Card Footer */
.card-footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F2F3F5;
  display: flex;
  justify-content: flex-end;
}

/* Failure Panel */
.failure-panel {
  background: rgba(255, 59, 48, 0.06);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  border: 1rpx solid rgba(255, 59, 48, 0.15);
}

.failure-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF3B30;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.failure-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 59, 48, 0.1);
}

.failure-item:last-child {
  border-bottom: none;
}

.failure-sku {
  font-size: 24rpx;
  color: #1F2329;
  font-weight: 500;
}

.failure-msg {
  font-size: 22rpx;
  color: #FF3B30;
  max-width: 50%;
  text-align: right;
}
