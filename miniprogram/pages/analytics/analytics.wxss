.container {
  padding: 32rpx;
  background: linear-gradient(180deg, #EEF2FF 0%, #F7F8FA 30%);
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 28rpx;
  padding: 0 8rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2329;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8F959E;
}

.summary-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.summary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #F2F3F5;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.summary-card.blue {
  border-left: 8rpx solid #3370FF;
}

.summary-card.green {
  border-left: 8rpx solid #34C759;
}

.summary-card.orange {
  border-left: 8rpx solid #FF9500;
}

.summary-label {
  display: block;
  font-size: 24rpx;
  color: #646A73;
  margin-bottom: 12rpx;
}

.summary-value {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #1F2329;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F2F3F5;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid #F2F3F5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2329;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: #3370FF;
  border-radius: 3rpx;
}

.section-count {
  font-size: 24rpx;
  color: #8F959E;
  background: #F2F3F5;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.refresh-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 28rpx;
  margin: 0;
  background: #3370FF;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 14rpx;
}

.refresh-btn[disabled] {
  background: #C4C4C4;
}

.pay-row,
.record-row {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.pay-row:last-child,
.record-row:last-child {
  border-bottom: none;
}

.pay-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.pay-main {
  min-width: 0;
  flex: 1;
}

.pay-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2329;
}

.pay-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8F959E;
}

.pay-amount,
.record-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #34C759;
  white-space: nowrap;
}

.record-top,
.record-meta,
.record-bottom {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.record-top {
  align-items: center;
  margin-bottom: 12rpx;
}

.record-item {
  min-width: 0;
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2329;
  word-break: break-all;
}

.record-meta {
  font-size: 24rpx;
  color: #646A73;
  margin-bottom: 10rpx;
}

.record-bottom {
  font-size: 22rpx;
  color: #8F959E;
}

.empty-state {
  text-align: center;
  padding: 56rpx 24rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #8F959E;
}
