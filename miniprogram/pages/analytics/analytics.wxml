<view class="container">
  <view class="header">
    <text class="title">数据分析</text>
    <text class="subtitle">今日销售概览 {{date}}</text>
  </view>

  <view class="summary-grid">
    <view wx:for="{{summaryCards}}" wx:key="key" class="summary-card {{item.tone}}">
      <text class="summary-label">{{item.label}}</text>
      <text class="summary-value">{{item.value}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">支付方式汇总</text>
      <button class="refresh-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="refresh">刷新</button>
    </view>

    <view wx:if="{{payMethods.length > 0}}" class="pay-list">
      <view wx:for="{{payMethods}}" wx:key="pay_method" class="pay-row">
        <view class="pay-main">
          <text class="pay-name">{{item.pay_method}}</text>
          <text class="pay-meta">{{item.count}} 笔 / {{item.quantity}} 件</text>
        </view>
        <text class="pay-amount">¥{{item.amountText}}</text>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-text">{{loading ? '正在加载销售数据' : '今日暂无销售记录'}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">销售明细</text>
      <text class="section-count">{{records.length}} 条</text>
    </view>

    <view wx:if="{{records.length > 0}}" class="record-list">
      <view wx:for="{{records}}" wx:key="record_id" class="record-row">
        <view class="record-top">
          <text class="record-item">{{item.item_no || '未填写货号'}}</text>
          <text class="record-amount">¥{{item.amountText}}</text>
        </view>
        <view class="record-meta">
          <text>{{item.color || '未填写颜色'}} / {{item.size || '尺码未知'}}</text>
          <text>{{item.quantity}} 件</text>
        </view>
        <view class="record-bottom">
          <text>{{item.pay_method}}</text>
          <text>{{item.sale_date}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-text">{{loading ? '正在加载销售明细' : '暂无明细'}}</text>
    </view>
  </view>
</view>
