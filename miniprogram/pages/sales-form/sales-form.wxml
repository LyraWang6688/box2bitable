<view class="container">
  <view class="header">
    <text class="title">{{title}}</text>
    <text class="subtitle">先提交金额和图片，识别完成后再统一复核</text>
  </view>

  <view class="form-card">
    <view wx:if="{{action === 'normal_sale'}}" class="field">
      <text class="label">销售金额</text>
      <input class="input" type="digit" placeholder="请输入本次实收金额" value="{{form.sale_amount}}" data-field="sale_amount" bindinput="onInput" />
    </view>

    <block wx:if="{{action === 'presale_order'}}">
      <view class="field">
        <text class="label">应收金额</text>
        <input class="input" type="digit" placeholder="请输入订单总金额" value="{{form.receivable_amount}}" data-field="receivable_amount" bindinput="onInput" />
      </view>

      <view class="field">
        <text class="label">支付状态</text>
        <picker mode="selector" range="{{paymentStatusOptions}}" bindchange="onPaymentStatusChange">
          <view class="picker-value">{{form.payment_status || '请选择'}}</view>
        </picker>
      </view>

      <view wx:if="{{form.payment_status === '部分收款'}}" class="field">
        <text class="label">已收金额</text>
        <input class="input" type="digit" placeholder="请输入定金金额" value="{{form.paid_amount}}" data-field="paid_amount" bindinput="onInput" />
      </view>

      <view class="field">
        <text class="label">客户姓名</text>
        <input class="input" placeholder="选填" value="{{form.customer_name}}" data-field="customer_name" bindinput="onInput" />
      </view>

      <view class="field">
        <text class="label">客户电话</text>
        <input class="input" type="number" placeholder="选填" value="{{form.customer_phone}}" data-field="customer_phone" bindinput="onInput" />
      </view>

      <view class="field">
        <text class="label">预计交付日期</text>
        <picker mode="date" value="{{form.expected_delivery_date}}" bindchange="onDateChange">
          <view class="picker-value">{{form.expected_delivery_date || '请选择'}}</view>
        </picker>
      </view>
    </block>

    <view wx:if="{{action === 'normal_sale' || form.payment_status === '部分收款'}}" class="field">
      <text class="label">收款方式</text>
      <picker mode="selector" range="{{payOptions}}" bindchange="onPayMethodChange">
        <view class="picker-value">{{form.pay_method || '请选择'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">备注</text>
      <input class="input" placeholder="选填" value="{{form.remark}}" data-field="remark" bindinput="onInput" />
    </view>
  </view>

  <view class="upload-card" bindtap="chooseImage">
    <view wx:if="{{!tempImagePath}}" class="upload-placeholder">
      <text class="upload-plus">+</text>
      <text class="upload-text">拍照或从相册选择</text>
    </view>
    <image wx:else class="preview-image" src="{{tempImagePath}}" mode="aspectFit"></image>
  </view>

  <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">提交识别任务</button>
</view>
