<view class="container">
  <view class="header">
    <text class="title">鞋盒标签识别</text>
    <text class="subtitle">当前模块：{{moduleLabel}} · 支持一图多条记录</text>
  </view>

  <view class="upload-section">
    <view class="upload-card" bindtap="chooseImage">
      <view class="upload-icon-shell" wx:if="{{!tempImagePath}}">
        <text class="upload-icon-glyph">+</text>
      </view>
      <image class="preview-image" src="{{tempImagePath}}" mode="aspectFit" wx:if="{{tempImagePath}}"></image>
      <text class="upload-tip">{{tempImagePath ? '点击更换图片' : '拍照或从相册选择'}}</text>
    </view>
  </view>

  <view class="action-section" wx:if="{{tempImagePath}}">
    <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="uploadAndRecognize">
      开始识别
    </button>
  </view>
</view>
