/* ============================================
   Entry Page - 录入模块选择页样式
   ============================================ */
.container {
  padding: 40rpx 32rpx;
  background: linear-gradient(180deg, #EEF2FF 0%, #F7F8FA 40%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Header Section */
.header {
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

.header-icon {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.header-icon-inner {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #3370FF 0%, #5B8DEF 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(51, 112, 255, 0.25);
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2329;
  letter-spacing: 1rpx;
}

.subtitle {
  margin-top: 16rpx;
  display: block;
  font-size: 26rpx;
  color: #8F959E;
  line-height: 1.6;
}

/* Cards Section */
.cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 8rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  border: 2rpx solid transparent;
}

.card::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(51, 112, 255, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  transform: translate(50%, -50%);
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.98);
  border-color: rgba(51, 112, 255, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.card:active::after {
  transform: translate(30%, -30%) scale(1.2);
}

/* Card Icon */
.card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.card-icon-purchase {
  background: linear-gradient(135deg, rgba(51, 112, 255, 0.15) 0%, rgba(91, 141, 239, 0.1) 100%);
}

.card-icon-sales {
  background: linear-gradient(135deg, rgba(255, 149, 0, 0.15) 0%, rgba(255, 183, 77, 0.1) 100%);
}

.card-icon-inventory {
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.15) 0%, rgba(46, 160, 67, 0.1) 100%);
}

/* Card Content */
.card-content {
  flex: 1;
  position: relative;
  z-index: 1;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2329;
  margin-bottom: 6rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #8F959E;
  line-height: 1.5;
}

/* Card Arrow */
.card-arrow {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C4C4C4;
  font-size: 28rpx;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.card:active .card-arrow {
  color: #3370FF;
  transform: translateX(4rpx);
}

/* Module Tags */
.module-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 60rpx;
  padding: 0 8rpx;
  justify-content: center;
}

.module-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(51, 112, 255, 0.06);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: #646A73;
}

.module-tag-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #3370FF;
}
