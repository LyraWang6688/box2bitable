/* ============================================
   Home Page - 首页样式
   ============================================ */
.container {
  padding: 40rpx 32rpx;
  background: linear-gradient(180deg, #EEF2FF 0%, #F7F8FA 40%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Header Section */
.header {
  text-align: center;
  padding: 60rpx 0 80rpx;
}

.logo-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #3370FF 0%, #5B8DEF 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(51, 112, 255, 0.3);
}

.logo-icon-inner {
  font-size: 56rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #1F2329;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.title-accent {
  background: linear-gradient(135deg, #3370FF 0%, #5B8DEF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  margin-top: 16rpx;
  display: block;
  font-size: 28rpx;
  color: #646A73;
  letter-spacing: 1rpx;
}

/* Cards Section */
.cards {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 0 8rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 28rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #3370FF 0%, #5B8DEF 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.card:active::before {
  opacity: 1;
}

/* Card Icon */
.card-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.card-icon-entry {
  background: linear-gradient(135deg, rgba(51, 112, 255, 0.12) 0%, rgba(91, 141, 239, 0.12) 100%);
}

.card-icon-query {
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.12) 0%, rgba(46, 160, 67, 0.12) 100%);
}

/* Card Content */
.card-content {
  flex: 1;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2329;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #8F959E;
  line-height: 1.5;
}

/* Card Arrow */
.card-arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C4C4C4;
  font-size: 32rpx;
  flex-shrink: 0;
}

/* Footer Tips */
.footer-tips {
  margin-top: 60rpx;
  padding: 24rpx;
  background: rgba(51, 112, 255, 0.06);
  border-radius: 16rpx;
  border: 1rpx solid rgba(51, 112, 255, 0.1);
}

.tips-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #3370FF;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #646A73;
  line-height: 1.6;
}
