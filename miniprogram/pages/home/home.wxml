<view class="container">
  <view class="header">
    <text class="title">box2bitable</text>
    <text class="subtitle">数据录入与库存查询</text>
  </view>

  <view class="cards">
    <view class="card" bindtap="goEntry">
      <text class="card-title">数据录入</text>
      <text class="card-desc">采购 / 销售 / 库存</text>
    </view>

    <view class="card" bindtap="goQuery">
      <text class="card-title">数据查询</text>
      <text class="card-desc">按货号查询库存尺码与数量</text>
    </view>

    <view class="card" bindtap="goAnalytics">
      <text class="card-title">数据分析</text>
      <text class="card-desc">查看今日销售额、数量与支付汇总</text>
    </view>
  </view>
</view>
