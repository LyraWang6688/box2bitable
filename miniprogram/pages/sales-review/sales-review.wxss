.container {
  padding: 32rpx;
  background: #F7F8FA;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2329;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8F959E;
}

.summary-card,
.section,
.notice {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #646A73;
}

.summary-row text:last-child {
  color: #1F2329;
  font-weight: 600;
}

.section-header,
.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title,
.item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2329;
}

.section-count,
.remove {
  font-size: 24rpx;
  color: #8F959E;
}

.remove {
  color: #FF3B30;
}

.item-card {
  padding: 24rpx 0;
  border-top: 1rpx solid #F2F3F5;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.field {
  width: calc(50% - 10rpx);
}

.field.full {
  width: 100%;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #646A73;
}

.input {
  height: 76rpx;
  background: #F7F8FA;
  border: 2rpx solid #E5E6EB;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1F2329;
  box-sizing: border-box;
}

.notice {
  font-size: 26rpx;
  color: #646A73;
  line-height: 1.6;
}

.notice.error {
  color: #FF3B30;
}

.btn-primary {
  width: 100% !important;
  height: 88rpx;
  line-height: 88rpx;
  background: #3370FF;
  color: #fff;
  font-size: 30rpx;
  border-radius: 16rpx;
}
