<view class="container">
  <view class="header">
    <text class="title">销售复核</text>
    <text class="subtitle">状态：{{statusLabel}}</text>
  </view>

  <view wx:if="{{task}}" class="summary-card">
    <view class="summary-row">
      <text>类型</text>
      <text>{{task.action_label}}</text>
    </view>
    <view class="summary-row" wx:if="{{task.input.sale_amount}}">
      <text>销售金额</text>
      <text>¥{{task.input.sale_amount}}</text>
    </view>
    <view class="summary-row" wx:if="{{task.input.receivable_amount}}">
      <text>应收金额</text>
      <text>¥{{task.input.receivable_amount}}</text>
    </view>
    <view class="summary-row" wx:if="{{task.input.paid_amount}}">
      <text>已收金额</text>
      <text>¥{{task.input.paid_amount}}</text>
    </view>
    <view class="summary-row" wx:if="{{task.input.pay_method}}">
      <text>收款方式</text>
      <text>{{task.input.pay_method}}</text>
    </view>
  </view>

  <view wx:if="{{canReview}}" class="section">
    <view class="section-header">
      <text class="section-title">识别子单</text>
      <text class="section-count">{{items.length}} 条</text>
    </view>

    <view wx:for="{{items}}" wx:key="sku_code" class="item-card">
      <view class="item-head">
        <text class="item-title">子单 {{index + 1}}</text>
        <text class="remove" bindtap="removeItem" data-index="{{index}}">删除</text>
      </view>
      <view class="grid">
        <view class="field">
          <text class="label">货号</text>
          <input class="input" value="{{item.item_no}}" data-index="{{index}}" data-field="item_no" bindinput="onInput" />
        </view>
        <view class="field">
          <text class="label">颜色</text>
          <input class="input" value="{{item.color}}" data-index="{{index}}" data-field="color" bindinput="onInput" />
        </view>
        <view class="field">
          <text class="label">尺码</text>
          <input class="input" type="number" value="{{item.size}}" data-index="{{index}}" data-field="size" bindinput="onInput" />
        </view>
        <view class="field">
          <text class="label">数量</text>
          <input class="input" type="number" value="{{item.quantity}}" data-index="{{index}}" data-field="quantity" bindinput="onInput" />
        </view>
        <view class="field full">
          <text class="label">默认售价</text>
          <input class="input" type="digit" placeholder="用于总单优惠分摊" value="{{item.default_price}}" data-index="{{index}}" data-field="default_price" bindinput="onInput" />
        </view>
      </view>
    </view>
  </view>

  <view wx:elif="{{task && (task.status === 'recognizing' || task.status === 'pending_recognition')}}" class="notice">
    <text>豆包仍在识别中，请稍后刷新待复核列表。</text>
  </view>

  <view wx:elif="{{task && task.status === 'recognition_failed'}}" class="notice error">
    <text>{{task.recognition_error || '识别失败'}}</text>
  </view>

  <view wx:elif="{{task && task.status === 'synced'}}" class="notice">
    <text>该任务已同步到飞书。</text>
  </view>

  <button wx:if="{{canReview}}" class="btn-primary" loading="{{syncing}}" disabled="{{syncing}}" bindtap="submitReview">
    确认并写入飞书
  </button>
</view>
