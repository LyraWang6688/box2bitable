<view class="container">
  <view class="header">
    <text class="title">销售录入</text>
    <text class="subtitle">新销售先提交识别任务，稍后集中复核</text>
  </view>

  <view class="cards">
    <view class="card" bindtap="goNormalSale">
      <view class="card-content">
        <text class="card-title">普通销售</text>
        <text class="card-desc">钱货两清，创建总单、子单和全款流水</text>
      </view>
      <text class="card-arrow">›</text>
    </view>

    <view class="card" bindtap="goPresaleOrder">
      <view class="card-content">
        <text class="card-title">预售订单</text>
        <text class="card-desc">先登记订单，可未收款或收定金</text>
      </view>
      <text class="card-arrow">›</text>
    </view>

    <view class="card" bindtap="goTasks">
      <view class="card-content">
        <text class="card-title">待复核销售</text>
        <text class="card-desc">查看豆包识别结果，确认后写入飞书</text>
      </view>
      <text class="card-arrow">›</text>
    </view>
  </view>
</view>
