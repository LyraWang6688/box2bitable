.container {
  padding: 40rpx 32rpx;
  background: linear-gradient(180deg, #EEF2FF 0%, #F7F8FA 40%);
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2329;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8F959E;
  line-height: 1.6;
}

.cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 8rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 24rpx;
  border: 2rpx solid transparent;
}

.card:active {
  transform: scale(0.98);
  border-color: rgba(51, 112, 255, 0.2);
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2329;
}

.card-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8F959E;
  line-height: 1.5;
}

.card-arrow {
  color: #C4C4C4;
  font-size: 42rpx;
}
