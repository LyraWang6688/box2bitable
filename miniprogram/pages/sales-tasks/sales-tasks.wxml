<view class="container">
  <view class="header">
    <text class="title">待复核销售</text>
    <text class="subtitle">识别完成后，确认子单并写入飞书</text>
  </view>

  <view wx:if="{{loadingText}}" class="loading-banner">
    <text>{{loadingText}}</text>
  </view>

  <view wx:if="{{tasks.length > 0}}" class="task-list">
    <view wx:for="{{tasks}}" wx:key="task_id" class="task-card" bindtap="openTask" data-id="{{item.task_id}}">
      <view class="task-top">
        <text class="task-title">{{item.action_label}}</text>
        <text class="status status-{{item.statusTone}}">{{item.statusLabel}}</text>
      </view>
      <view class="task-desc">{{item.statusDescription}}</view>
      <view class="task-meta">
        <text>识别结果：{{item.itemCount}} 条</text>
        <text>{{item.created_at}}</text>
      </view>
      <view class="task-money">
        <text wx:if="{{item.input.sale_amount}}">销售金额 ¥{{item.input.sale_amount}}</text>
        <text wx:elif="{{item.input.receivable_amount}}">应收金额 ¥{{item.input.receivable_amount}}</text>
        <text wx:if="{{item.input.pay_method}}">{{item.input.pay_method}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <text class="empty-text">{{loading ? '正在加载销售任务' : '暂无待复核销售单'}}</text>
  </view>
</view>
