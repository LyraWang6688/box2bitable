.container {
  padding: 32rpx;
  background: #F7F8FA;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 28rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2329;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8F959E;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #F2F3F5;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.task-top,
.task-meta,
.task-money {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2329;
}

.status {
  font-size: 22rpx;
  color: #3370FF;
  background: rgba(51, 112, 255, 0.08);
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  white-space: nowrap;
}

.status-recognition_failed,
.status-sync_failed {
  color: #FF3B30;
  background: rgba(255, 59, 48, 0.08);
}

.status-synced {
  color: #34C759;
  background: rgba(52, 199, 89, 0.08);
}

.task-meta {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #8F959E;
}

.task-money {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #646A73;
}

.empty {
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #8F959E;
}
